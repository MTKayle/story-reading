# ===========================================
# Story Reading Platform - Environment Variables
# ===========================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to Git!

# ===========================================
# Database Configuration
# ===========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Database Names
DB_USER=userdb
DB_STORY=storydb
DB_PAYMENT=paymentdb
DB_COMMENT=commentdb
DB_NOTIFICATION=notificationdb

# ===========================================
# JWT Configuration
# ===========================================
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_here_minimum_256_bits
JWT_EXPIRATION=3600000

# ===========================================
# RabbitMQ Configuration
# ===========================================
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=your_rabbitmq_password_here
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

# ===========================================
# Email Configuration (Gmail SMTP)
# ===========================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password_here
# Get app password: https://myaccount.google.com/apppasswords

# ===========================================
# VNPay Payment Gateway
# ===========================================
# Sandbox credentials (for testing)
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_HASH_SECRET=your_vnpay_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:8084/api/payment/vnpay/callback

# Production credentials (uncomment for production)
# VNPAY_TMN_CODE=your_production_vnpay_tmn_code
# VNPAY_HASH_SECRET=your_production_vnpay_hash_secret
# VNPAY_URL=https://vnpayment.vn/paymentv2/vpcpay.html

# ===========================================
# Application URLs
# ===========================================
FRONTEND_BASE_URL=http://localhost:5173
API_GATEWAY_URL=http://localhost:8081

# ===========================================
# Service URLs (Internal Docker Network)
# ===========================================
USER_SERVICE_URL=http://user-service:8882
STORY_SERVICE_URL=http://story-service:8085
PAYMENT_SERVICE_URL=http://payment-service:8084
COMMENT_SERVICE_URL=http://comment-service:8883
NOTIFICATION_SERVICE_URL=http://notification-service:8087

# ===========================================
# Redis Configuration (Optional)
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ===========================================
# Monitoring & Logging (Optional)
# ===========================================
LOG_LEVEL=INFO
SPRING_PROFILES_ACTIVE=prod

# ===========================================
# Security Settings
# ===========================================
# Enable/disable features
ENABLE_SWAGGER=false
ENABLE_ACTUATOR=true
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
